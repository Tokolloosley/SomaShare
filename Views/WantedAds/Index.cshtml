@model IEnumerable<SomaShare.Models.WantedAd>

@{
    ViewData["Title"] = "Wanted Ads";
}

<h1>Wanted Ads</h1>

@if (User.Identity.IsAuthenticated)
{
    <a asp-action="Create" class="btn btn-success mb-3">+ Post Wanted Ad</a>
}

@if (Model.Count() == 0)
{
    <p>No wanted ads at the moment.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>ISBN</th>
                    <th>Max Price</th>
                    <th>Posted By</th>
                    <th>Posted Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ad in Model)
                {
                    <tr>
                        <td>@ad.Title</td>
                        <td>@ad.Author</td>
                        <td>@ad.ISBN</td>
                        <td>R @ad.MaxPrice.ToString("N2")</td>
                        <td>@ad.User.FirstName @ad.User.LastName</td>
                        <td>@ad.CreatedDate.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (ad.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td>
                            @if (User.Identity.IsAuthenticated && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == ad.UserId)
                            {
                                <a asp-action="Edit" asp-route-id="@ad.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@ad.Id" class="btn btn-sm btn-danger">Delete</a>
                            }
                            else if (User.Identity.IsAuthenticated && User.IsInRole("Seller"))
                            {
                                <a asp-controller="Offers" asp-action="CreateForWantedAd" asp-route-wantedAdId="@ad.Id" class="btn btn-sm btn-primary">Offer Book</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}